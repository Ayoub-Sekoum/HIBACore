# ─────────────────────────────────────────────────────────────────────────────
# Environment — copy to .env and fill in your values
# NEVER commit .env to the repository
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
ENVIRONMENT=local          # local | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_FAST_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_NORMAL_DEPLOYMENT=gpt-4o
AZURE_OPENAI_DEEP_DEPLOYMENT=o1-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ── Azure Identity ────────────────────────────────────────────────────────────
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-client-id>
# AZURE_CLIENT_SECRET is only needed for non-Managed-Identity deployments

# ── Azure AI Project (DeepAgents) ────────────────────────────────────────────
AZURE_AI_PROJECT_ENDPOINT=https://<your-ai-foundry>.services.ai.azure.com/

# ── Cosmos DB (chat history) ─────────────────────────────────────────────────
COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
COSMOS_DATABASE_NAME=chat_db
COSMOS_CONTAINER_NAME=messages

# ── PostgreSQL + pgvector (semantic memory) ──────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=chat_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Azure AI Search (RAG) ─────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_INDEX_NAME=documents
AZURE_SEARCH_API_KEY=<your-search-key>

# ── Redis (rate limiting) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Azure Service Bus (async workers) ────────────────────────────────────────
AZURE_SERVICE_BUS_FQDN=<your-servicebus>.servicebus.windows.net

# ── Azure Key Vault ───────────────────────────────────────────────────────────
AZURE_KEYVAULT_URL=https://<your-keyvault>.vault.azure.net/

# ── Azure Content Safety ─────────────────────────────────────────────────────
AZURE_CONTENT_SAFETY_ENDPOINT=https://<your-content-safety>.cognitiveservices.azure.com/

# ── App Configuration ─────────────────────────────────────────────────────────
AZURE_APP_CONFIG_ENDPOINT=https://<your-appconfig>.azconfig.io

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Skill Engine ─────────────────────────────────────────────────────────────
SKILL_ENGINE_URL=http://localhost:3000

# ── ZeroClaw Agent (optional external agent) ─────────────────────────────────
ZEROCLAW_ENABLED=false
ZEROCLAW_GATEWAY_URL=http://localhost:8080

# ── Microsoft Authentication (MSAL frontend) ─────────────────────────────────
VITE_AZURE_CLIENT_ID=<your-spa-client-id>
VITE_AZURE_TENANT_ID=<your-tenant-id>
VITE_API_BASE_URL=http://localhost:8000

# ── Air-gapped mode (local dev without Azure) ────────────────────────────────
AIRGAPPED_MODE=false
OLLAMA_BASE_URL=http://localhost:11434
